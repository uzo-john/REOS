{
  "name": "reos-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Renewable Energy Operating System (REOS) Monorepo",
  "workspaces": [
    "apps/backend",
    "apps/frontend",
    "packages/*"
  ],
  "scripts": {
    "backend:dev": "npm run start:dev --workspace=apps/backend",
    "backend:build": "npm run build --workspace=apps/backend",
    "frontend:start": "npm run start --workspace=apps/frontend",
    "test": "npm run test --workspaces"
  }
}
