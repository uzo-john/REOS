{
  "name": "reos-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Renewable Energy Operating System (REOS) Monorepo",
  "workspaces": [
    "apps/backend",
    "apps/frontend",
    "packages/*"
  ],
  "scripts": {
    "backend:dev": "npm run start:dev --workspace=apps/backend",
    "backend:build": "npm run build --workspace=apps/backend",
    "frontend:start": "npm run start --workspace=apps/frontend",
    "frontend:web": "npm run web --workspace=apps/frontend",
    "frontend:build": "npm run build --workspace=@reos/types && npm run build --workspace=@reos/validation && npm run build --workspace=@reos/engineering && npm run build --workspace=@reos/ui && npm run build --workspace=apps/frontend",
    "test": "npm run test --workspaces"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "react-native": "^0.85.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
