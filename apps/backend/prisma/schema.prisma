datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

enum UserRole {
  CUSTOMER
  SYSTEM_OWNER
  CONSUMER
  INSTALLER
  ENGINEER
  ADMIN
  PLANT_OPERATOR
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  passwordHash        String
  firstName           String
  lastName            String
  role                UserRole             @default(SYSTEM_OWNER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  refreshToken        String?
  projects            Project[]
  auditLogs           AuditLog[]
  contractsAsSupplier EnergyContract[]     @relation("SupplierContracts")
  contractsAsConsumer EnergyContract[]     @relation("ConsumerContracts")
  invitationsSent     ConsumerInvitation[] @relation("SentInvitations")
  notifications       Notification[]
  devices             Device[]
}

model Project {
  id           String             @id @default(uuid())
  name         String
  description  String?
  location     String?
  latitude     Float?
  longitude    Float?
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  appliances   ProjectAppliance[]
  designs      ProjectDesign[]
  simulations  SimulationResult[]
  quotations   Quotation[]
  devices      Device[]
}

model Appliance {
  id           String             @id @default(uuid())
  name         String
  defaultPower Float              // In Watts
  category     String             // e.g., Kitchen, Cooling, Lighting
  isCustom     Boolean            @default(false)
  projects     ProjectAppliance[]
}

model ProjectAppliance {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  applianceId String
  appliance   Appliance @relation(fields: [applianceId], references: [id])
  quantity    Int       @default(1)
  hoursOnDay  Float[]   // Array of 24 floats representing load profile per hour (0.0 to 1.0)
  createdAt   DateTime  @default(now())
}

model ProjectDesign {
  id                     String   @id @default(uuid())
  projectId              String
  project                Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  
  // PV Parameters
  pvModulePower          Float?   // Watts
  pvModuleQty            Int?
  pvTotalPower           Float?   // kW
  
  // Battery Parameters
  batteryCapacityAh      Float?
  batteryVoltage         Float?
  batteryDepthOfDischarge Float?
  batteryQty             Int?
  
  // Inverter Parameters
  inverterPowerRating    Float?   // kW
  inverterEfficiency     Float?   // percentage
  
  // MPPT Parameters
  mpptCurrentRating      Float?   // Amps
  
  // Cables & Protection
  cableSizeMm2           Float?
  fuseRatingAmps         Float?
  circuitBreakerAmps     Float?
}

model SimulationResult {
  id                String   @id @default(uuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  
  // Generation & Demand Profiles
  hourlySolarGen    Float[]  // 24 hours of solar generation in kWh
  hourlyLoadDemand  Float[]  // 24 hours of load demand in kWh
  hourlyBatterySoC  Float[]  // 24 hours of Battery State-of-Charge percentage
  
  // Financial Outcomes
  totalCost         Float
  paybackPeriodYrs  Float
  roiPercentage     Float
  exportedGridKwh   Float
  gridRevenueEarned Float
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // e.g., "USER_LOGIN", "PROJECT_CREATE", "CALCULATION_RUN"
  details   String?  // JSON string or summary
  ipAddress String?
  createdAt DateTime @default(now())
}

model Product {
  id        String            @id @default(uuid())
  name      String
  category  String            // e.g. PANEL, BATTERY, INVERTER
  model     String
  rating    Float             // e.g., watts, Ah, kW
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  suppliers SupplierProduct[]
}

model Supplier {
  id        String            @id @default(uuid())
  name      String
  contact   String?
  rating    Float             @default(5.0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  products  SupplierProduct[]
}

model SupplierProduct {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  price      Float
  stock      Int      @default(0)
  leadTime   Int      @default(1) // in days
}

model Installer {
  id        String      @id @default(uuid())
  name      String
  contact   String
  rating    Float       @default(5.0)
  baseRate  Float       // base rate for standard install in local currency
  location  String
  quotes    Quotation[]
}

model Quotation {
  id                String     @id @default(uuid())
  projectId         String
  project           Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  installerId       String?
  installer         Installer? @relation(fields: [installerId], references: [id], onDelete: SetNull)
  totalHardwareCost Float
  installationCost  Float
  grandTotal        Float
  itemsJson         String     // JSON serialized list of products included
  createdAt         DateTime   @default(now())
}

model ConsumerInvitation {
  id             String    @id @default(uuid())
  invitationCode String    @unique
  supplierId     String
  supplier       User      @relation("SentInvitations", fields: [supplierId], references: [id], onDelete: Cascade)
  email          String?
  phoneNumber    String?
  status         String    @default("PENDING") // PENDING, ACCEPTED, REJECTED, EXPIRED
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model EnergyContract {
  id               String        @id @default(uuid())
  supplierId       String
  supplier         User          @relation("SupplierContracts", fields: [supplierId], references: [id], onDelete: Cascade)
  consumerId       String
  consumer         User          @relation("ConsumerContracts", fields: [consumerId], references: [id], onDelete: Cascade)
  connectionStatus String        @default("ACTIVE") // ACTIVE, SUSPENDED, TERMINATED
  contractDate     DateTime      @default(now())
  tariffRate       Float         // Price in local currency per kWh (e.g. NGN/kWh)
  billingCycle     String        @default("PREPAID") // PREPAID, POSTPAID, HYBRID
  balance          Float         @default(0.0) // wallet balance for prepaid or outstanding for postpaid
  gatewayId        String?       // Edge gateway handling the link
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  invoices         Invoice[]
  transactions     Transaction[]
}

model Device {
  id                   String        @id @default(uuid())
  name                 String
  type                 String        // SMART_METER, INVERTER, BMS, CHARGE_CONTROLLER, EDGE_GATEWAY, etc.
  manufacturer         String?
  model                String?
  firmwareVersion      String?
  protocol             String        @default("MQTT") // MODBUS_RTU, MODBUS_TCP, MQTT, HTTP
  status               String        @default("ONLINE") // ONLINE, OFFLINE, MAINTENANCE
  signalStrength       Int?          // dBm
  communicationQuality Int?          // 0-100%
  lastCommTime         DateTime      @default(now())
  ownerId              String?
  owner                User?         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  projectId            String?
  project              Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  telemetry            Telemetry[]
}

model Telemetry {
  id              String   @id @default(uuid())
  deviceId        String
  device          Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  timestamp       DateTime @default(now())
  voltage         Float?
  current         Float?
  activePower     Float?
  reactivePower   Float?
  apparentPower   Float?
  frequency       Float?
  powerFactor     Float?
  energyImported  Float?
  energyExported  Float?
  batterySoc      Float?
  status          String?
  alarmStatus     String?
  commQuality     Float?
}

model Invoice {
  id                String         @id @default(uuid())
  contractId        String
  contract          EnergyContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  amount            Float
  tariffRate        Float
  energyReceivedKwh Float
  billingPeriodStart DateTime
  billingPeriodEnd  DateTime
  dueDate           DateTime
  status            String         @default("UNPAID") // PAID, UNPAID, OVERDUE
  pdfUrl            String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Transaction {
  id             String         @id @default(uuid())
  contractId     String
  contract       EnergyContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  type           String         // PREPAID_PURCHASE, BILL_PAYMENT, CREDIT_TRANSFER
  amount         Float
  currency       String         @default("NGN")
  paymentGateway String?
  status         String         @default("SUCCESSFUL") // PENDING, SUCCESSFUL, FAILED
  reference      String?        @unique
  createdAt      DateTime       @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("INFO") // ALERT, BILLING, SYSTEM, INFO
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

